# ============================================================
# 幻境AIGC — 环境变量配置模板
# 复制此文件为 .env.local 并填写实际值
# cp .env.example .env.local
# ============================================================

# ----- 硅基流动 API (图片/视频生成) -----
# 获取地址: https://siliconflow.cn
# 图片模型推荐: Tongyi-MAI/Z-Image-Turbo, Qwen/Qwen2-VL-72B-Instruct, stabilityai/stable-diffusion-3-medium-native
# 视频模型推荐: Wan-AI/Wan2.2-I2V-A14B, tencent/hunyuan-video
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1
SILICONFLOW_IMAGE_MODEL=Tongyi-MAI/Z-Image-Turbo
SILICONFLOW_VIDEO_MODEL=Wan-AI/Wan2.2-I2V-A14B

# ----- Supabase 数据库 (必填) -----
# 从 Supabase Dashboard → Settings → API 获取
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----- MinIO 对象存储 (图片/视频文件持久化) -----
# MinIO 服务地址，必须包含协议和端口，例如:
#   http://127.0.0.1:9000
#   https://minio.yourdomain.com
MINIO_ENDPOINT=http://127.0.0.1:9000
# MinIO 访问凭证 (Access Key)
MINIO_ACCESS_KEY=minioadmin
# MinIO 访问凭证 (Secret Key)
MINIO_SECRET_KEY=minioadmin
# 存储桶名称 (默认 media)
MINIO_BUCKET=media
# MinIO 区域标识 (默认 us-east-1)
# MINIO_REGION=us-east-1
# 是否使用 HTTPS 连接 (默认 false)，设为 true 强制 https://
# MINIO_USE_SSL=false
# 公开访问基地址 (推荐配置)，用于构造外部可访问的下载 URL
# 例如: https://minio.yourdomain.com/media 或 https://cdn.yourdomain.com
# 设置后，生成的图片/视频将以该域名对外提供
# MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000/media
# 桶是否为公开读 (默认跟随 MINIO_PUBLIC_BASE_URL 设置)
# 设为 true 时直接返回公开 URL，false 时返回预签名 URL (有效期 30 天)
# MINIO_PUBLIC_READ=false
# 预签名 URL 有效期，单位秒 (默认 2592000 = 30天)
# MINIO_SIGNED_URL_EXPIRES_IN=2592000

# ----- 服务端口 (可选) -----
# 默认 5000，一般无需修改
# DEPLOY_RUN_PORT=5000

# ----- 管理员注册邀请码 (可选) -----
# 注册时输入此邀请码可创建管理员账号
# 默认值: huanjing-aigc-admin-2026
# ADMIN_INVITE_CODE=huanjing-aigc-admin-2026

# ----- 运行环境 (可选) -----
# DEV = 开发环境, PROD = 生产环境
# APP_ENV=PROD

# ----- 项目域名 (可选) -----
# 用于构造回调 URL、分享链接等
# APP_DOMAIN=https://your-domain.com

# ============================================================
# 说明:
# - 不配置 Supabase 时，系统将运行在 Demo 模式
#   Demo 模式下：登录/注册返回模拟数据，公告/网站配置返回默认值
#   管理后台写入操作将返回 503 错误
#
# - 要启用完整功能，需要:
#   1. 创建 Supabase 项目
#   2. 运行 scripts/init-database.sql 初始化数据库
#   3. 在 Supabase Dashboard 创建 site-assets Storage 桶 (公开读)
#   4. 填写以上 Supabase 环境变量
#
# - AI 图片/视频生成使用硅基流动 API
#   用户也可以在前端"自定义 API"中配置自己的 API 密钥
#
# - 媒体文件存储使用 MinIO (兼容 S3 API)
#   图片/视频生成后自动上传到 MinIO 桶
#   作品信息同步写入 Supabase works 表
#   画廊展示公开作品 (is_public = true)
#
# - MinIO 桶存储结构:
#   generated/images/  - AI 生成的图片
#   generated/videos/  - AI 生成的视频
#   img2img-ref/       - 图生图参考图片
#   img2vid-ref/       - 图生视频参考图片
# ============================================================
